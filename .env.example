# Copy to `.env`, fill in ONE provider's API key, restart dev server (`npm run dev`).
# Vite only exposes VITE_* vars to the browser — never commit `.env`.

# Which provider to use: groq | gemini | openrouter
VITE_AI_PROVIDER=groq

# =============================================================================
# OPTION 1 — Groq (recommended, free, no credit card)
# =============================================================================
# 1. Sign up: https://console.groq.com
# 2. Left menu → API Keys → Create API Key
# 3. Paste key below (starts with gsk_...)
# Docs: https://console.groq.com/docs/quickstart
VITE_GROQ_API_KEY=

# Optional Groq overrides
# VITE_GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
# VITE_GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# OPTION 2 — Google Gemini (free tier via Google AI Studio)
# =============================================================================
# 1. Sign in: https://aistudio.google.com/apikey
# 2. Click "Create API key"
# 3. Set VITE_AI_PROVIDER=gemini and paste key below
# Docs: https://ai.google.dev/gemini-api/docs
# VITE_GEMINI_API_KEY=
# VITE_GEMINI_MODEL=gemini-2.0-flash

# =============================================================================
# OPTION 3 — OpenRouter (free models, no payment for some models)
# =============================================================================
# 1. Sign up: https://openrouter.ai
# 2. Keys → Create key
# 3. Set VITE_AI_PROVIDER=openrouter and paste key below
# Free model list: https://openrouter.ai/models?q=free
# VITE_OPENROUTER_API_KEY=
# VITE_OPENROUTER_MODEL=google/gemma-2-9b-it:free
